#!/usr/bin/env bash
#MISE description="Run plugin tests - install and execute tool"
set -euo pipefail

mise plugin link --force docker-health .
mise cache clear
mise install docker-health@1.3.0

# Capture and display the output while also verifying it
output=$(mise exec "docker-health@1.3.0" -- "docker-health" --version)
echo "docker-health output: ${output}"

if echo "${output}" | grep -q '1.3.0'; then
  echo "✓ Tests passed"
else
  echo "✗ Test failed: expected version docker-health@1.3.0"
  exit 1
fi
